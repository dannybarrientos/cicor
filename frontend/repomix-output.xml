import { NavLink, useLocation } from 'react-router-dom'
import { useState } from 'react'

const MODULES = [
  { path: '/',            label: 'Dashboard',        code: '⌂',  color: '#1E40AF' },
  { path: '/commercial',  label: 'Comercial',         code: 'C',  color: '#10B981' },
  { path: '/inventory',   label: 'Inventario',        code: 'I',  color: '#3B82F6' },
  { path: '/accounting',  label: 'Contabilidad',      code: 'C',  color: '#EF4444' },
  { path: '/operations',  label: 'Operaciones',       code: 'O',  color: '#F97316' },
  { path: '/hr',          label: 'Rec. Humanos',      code: 'R',  color: '#A855F7' },
]

export default function Navbar() {
  const [mobileOpen, setMobileOpen] = useState(false)
  const location = useLocation()

  return (
    <header className="fixed top-0 left-0 right-0 z-50 h-16"
            style={{ background: '#0C1E4D', borderBottom: '1px solid rgba(255,255,255,0.08)' }}>
      <div className="max-w-7xl mx-auto h-full flex items-center justify-between px-4 lg:px-6">

        {/* Logo */}
        <NavLink to="/" className="flex items-center gap-2.5 group">
          <div className="w-8 h-8 rounded-lg flex items-center justify-center font-display font-bold text-sm"
               style={{ background: 'linear-gradient(135deg, #1E40AF, #3B82F6)', color: '#fff', letterSpacing: '-0.5px' }}>
            C
          </div>
          <span className="font-display font-bold text-white text-lg tracking-tight">
            CICOR <span className="text-blue-300 font-light text-sm">ERP</span>
          </span>
        </NavLink>

        {/* Desktop nav */}
        <nav className="hidden md:flex items-center gap-1">
          {MODULES.map(({ path, label, code, color }) => {
            const isExact = path === '/' ? location.pathname === '/' : location.pathname.startsWith(path)
            return (
              <NavLink key={path} to={path}
                className={`flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150 ${
                  isExact
                    ? 'text-white'
                    : 'text-blue-200 hover:text-white hover:bg-white/10'
                }`}
                style={isExact ? { background: `${color}22`, color } : {}}
              >
                <span className="w-5 h-5 rounded flex items-center justify-center text-xs font-bold"
                      style={{ background: isExact ? color : 'transparent',
                               color: isExact ? '#fff' : color,
                               border: `1.5px solid ${color}` }}>
                  {code}
                </span>
                {label}
              </NavLink>
            )
          })}
        </nav>

        {/* Environment badge */}
        <div className="hidden md:flex items-center gap-2">
          <span className="text-xs font-mono px-2 py-0.5 rounded-full"
                style={{ background: 'rgba(16,185,129,0.15)', color: '#34D399', border: '1px solid rgba(16,185,129,0.3)' }}>
            <span className="inline-block w-1.5 h-1.5 rounded-full bg-emerald-400 mr-1.5 align-middle"
                  style={{ animation: 'pulseDot 2s infinite' }} />
            LOCAL
          </span>
        </div>

        {/* Mobile hamburger */}
        <button className="md:hidden text-white p-2 rounded-lg hover:bg-white/10"
                onClick={() => setMobileOpen(o => !o)}
                aria-label="Toggle menu">
          <svg className="w-5 h-5" fill="none" stroke="currentColor" strokeWidth={2} viewBox="0 0 24 24">
            {mobileOpen
