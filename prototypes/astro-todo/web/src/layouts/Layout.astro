---
import { PAGE_TITLE, PRIMARY_COLOR, PRIMARY_DARK, MODULE_NAME } from "../lib/config";

import '@/styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = PAGE_TITLE,
  description = `CICOR – Gestión de tareas para el módulo ${MODULE_NAME}`,
} = Astro.props;
---


<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style define:vars={{ primaryColor: PRIMARY_COLOR, primaryDark: PRIMARY_DARK }}>
      :root {
        --color-primary: var(--primaryColor);
        --color-primary-dark: var(--primaryDark);
      }
    </style>
  </head>
  <body class="bg-[#0a0a0f] text-zinc-100 font-body antialiased min-h-screen">
    <slot />
  </body>
</html>
