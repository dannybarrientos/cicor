# ── Module identity ────────────────────────────────────────────────────────────
# This value flows into both the API (response metadata) and the web UI (title,
# labels, meta tags). Change it to reflect the specific CICOR module.
MODULE_NAME=App
MODULE_VERSION=1.0.0

# ── Theme (web only) ───────────────────────────────────────────────────────────
# Optional – if omitted the web defaults to indigo (#6366f1 / #4f46e5)
PRIMARY_COLOR=#6366f1
PRIMARY_DARK=#4f46e5

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=cicor
DB_PASSWORD=cicor
DB_NAME=cicor
DB_PORT=5432

# ── Ports ──────────────────────────────────────────────────────────────────────
API_PORT=8000
WEB_PORT=80

# ── Dev flags ─────────────────────────────────────────────────────────────────
DEBUG=false
