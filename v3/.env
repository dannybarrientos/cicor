# ============================================================
# CICOR ERP - Variables de Entorno Locales
# Copiar a .env y ajustar según necesidad
# ============================================================

# ── FRONTEND ──────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost

# ── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ── API PORTS (host) ──────────────────────────────────────
COMMERCIAL_API_PORT=8001
INVENTORY_API_PORT=8002
ACCOUNTING_API_PORT=8003
OPERATIONS_API_PORT=8004
HR_API_PORT=8005

# ── DATABASE CREDENTIALS (todos usan el mismo user/pass) ──
DB_USER=cicor_user
DB_PASSWORD=cicor_pass

# ── COMMERCIAL BD ─────────────────────────────────────────
COMMERCIAL_DB_USER=cicor_user
COMMERCIAL_DB_PASSWORD=cicor_pass
COMMERCIAL_DB_NAME=cicor_commercial_db
COMMERCIAL_DB_PORT_HOST=5431

# ── INVENTORY BD ──────────────────────────────────────────
INVENTORY_DB_USER=cicor_user
INVENTORY_DB_PASSWORD=cicor_pass
INVENTORY_DB_NAME=cicor_inventory_db
INVENTORY_DB_PORT_HOST=5432

# ── ACCOUNTING BD ─────────────────────────────────────────
ACCOUNTING_DB_USER=cicor_user
ACCOUNTING_DB_PASSWORD=cicor_pass
ACCOUNTING_DB_NAME=cicor_accounting_db
ACCOUNTING_DB_PORT_HOST=5433

# ── OPERATIONS BD ─────────────────────────────────────────
OPERATIONS_DB_USER=cicor_user
OPERATIONS_DB_PASSWORD=cicor_pass
OPERATIONS_DB_NAME=cicor_operations_db
OPERATIONS_DB_PORT_HOST=5434

# ── HR BD ─────────────────────────────────────────────────
HR_DB_USER=cicor_user
HR_DB_PASSWORD=cicor_pass
HR_DB_NAME=cicor_hr_db
HR_DB_PORT_HOST=5435

# ── ENVIRONMENT ───────────────────────────────────────────
REACT_APP_ENVIRONMENT=local