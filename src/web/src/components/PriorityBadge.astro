---
const { priority } = Astro.props as { priority: 'low' | 'medium' | 'high' };    

const config = {
  low: {
    label: "Baja",
    color: "text-emerald-400",
    bg: "bg-emerald-400/10 border-emerald-400/30"
  },
  medium: {
    label: "Media",
    color: "text-amber-400",
    bg: "bg-amber-400/10 border-amber-400/30"
  },
  high: {
    label: "Alta",
    color: "text-rose-400",
    bg: "bg-rose-400/10 border-rose-400/30"
  }
};

const cfg = config[priority];
---

<span
  class={`inline-flex items-center px-2 py-1 rounded-full border text-xs ${cfg.bg} ${cfg.color}`}
>
  {cfg.label}
</span>