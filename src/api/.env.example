# Module identity
MODULE_NAME=App
MODULE_VERSION=1.0.0

# Database (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://cicor:cicor@db:5432/cicor

# CORS – comma-separated list handled via JSON array in pydantic-settings
CORS_ORIGINS=["http://localhost:4321","http://localhost:3000"]

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
